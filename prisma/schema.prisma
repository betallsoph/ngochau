datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  phone           String           @unique
  passwordHash    String
  name            String
  avatar          String?
  role            String           @default("TENANT") // "SUPER_ADMIN" | "LANDLORD" | "STAFF" | "TENANT"
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Mối quan hệ tương ứng với vai trò
  landlordProfile LandlordProfile?
  tenantProfile   TenantProfile?
  staffProfile    StaffProfile?
}

model LandlordProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionType String       @default("FREE") // FREE, PREMIUM, ENTERPRISE
  subValidUntil   DateTime?
  companyName     String?
  
  // Thông tin ngân hàng nhận tiền chuyển khoản (Cấu hình riêng của mỗi chủ trọ)
  bankName        String        @default("Vietcombank")
  bankCode        String        @default("VCB")
  accountNumber   String        @default("1234567890")
  accountName     String        @default("NGUYEN VAN HAU")
  bankBranch      String        @default("Chi nhánh TP.HCM")

  properties      Property[]
  services        Service[]     // Bảng dịch vụ tùy biến của chủ trọ này
  staffs          StaffProfile[]
}

model StaffProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  landlordId      String
  landlord        LandlordProfile    @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  assignedRequests MaintenanceRequest[]
}

model TenantProfile {
  id             String               @id @default(uuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  idNumber       String               // CCCD
  idFrontImage   String?              // Ảnh chụp CCCD trước
  idBackImage    String?              // Ảnh chụp CCCD sau
  vehicleImage   String?              // Ảnh xe máy/Cà vẹt
  checkInImage   String?              // Ảnh chụp lúc bàn giao phòng
  moveInDate     String
  deposit        Float
  notes          String?
  
  rooms          Room[]
  requests       MaintenanceRequest[]
  specialNotes   SpecialNote[]        // Lời nhắn lưu ý gửi chủ trọ
}

model Property {
  id              String           @id @default(uuid())
  landlordId      String
  landlord        LandlordProfile  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  name            String
  shortName       String
  address         String
  createdAt       DateTime         @default(now())
  
  blocks          Block[]
  rooms           Room[]
}

model Block {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String    // ví dụ: "Block A", "Khu nhà cấp 4"
  rooms       Room[]
}

model Service {
  id              String           @id @default(uuid())
  landlordId      String
  landlord        LandlordProfile  @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  name            String           // ví dụ: "Điện", "Nước", "Wifi", "Gửi xe máy"
  type            String           // "METERED" | "FLAT_ROOM" | "FLAT_PERSON" | "FLAT_VEHICLE"
  defaultRate     Float            // Đơn giá chuẩn áp dụng cho toàn bộ cơ sở
  isActive        Boolean          @default(true)

  configs         RoomServiceConfig[]
}

model Room {
  id             String              @id @default(uuid())
  propertyId     String
  blockId        String?
  property       Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  block          Block?              @relation(fields: [blockId], references: [id], onDelete: SetNull)
  roomNumber     String
  roomCode       String?             // Mã căn hộ
  roomType       String              // 'standard' | 'master' | 'balcony'
  floor          Int?
  status         String              // 'empty' | 'paid' | 'debt'
  monthlyRent    Float
  area           Float?
  debtAmount     Float?              @default(0)
  tenantId       String?
  tenant         TenantProfile?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  
  services       RoomServiceConfig[] // Các dịch vụ phòng này đăng ký sử dụng
  meterReadings  MeterReading[]
  invoices       Invoice[]
  assets         RoomAsset[]         // Quản lý thiết bị bàn giao phòng
}

model RoomServiceConfig {
  id            String   @id @default(uuid())
  roomId        String
  serviceId     String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customRate    Float?   // Nếu không null, ghi đè đơn giá defaultRate của Service
  quantity      Int      @default(1) // Số lượng đăng ký (áp dụng cho xe máy, số người)
}

model MeterReading {
  id              String   @id @default(uuid())
  roomId          String
  serviceId       String   // Chỉ số đo lường cho dịch vụ nào (Ví dụ dịch vụ Điện / Nước)
  month           String   // Định dạng YYYY-MM
  prevValue       Float
  currValue       Float
  recordedAt      String   // YYYY-MM-DD
  photoUrl        String?  // Lưu trữ ảnh chụp đồng hồ đối chiếu
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                String        @id
  roomId            String
  roomNumber        String
  tenantName        String
  tenantPhone       String
  month             String        // YYYY-MM
  rentAmount        Float
  totalAmount       Float
  dueDate           String        // YYYY-MM-DD
  paidDate          String?       // YYYY-MM-DD
  status            String        // 'paid' | 'pending' | 'overdue' | 'partial'
  paidAmount        Float         @default(0) // Số tiền đã trả
  paymentProofImage String?       // Ảnh chụp hóa đơn/bill chuyển khoản
  createdAt         String        // YYYY-MM-DD
  notes             String?
  room              Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String   // ví dụ: "Tiền phòng", "Tiền điện tháng 5", "Wifi"
  amount      Float
  details     String?  // ví dụ: "Chỉ số: 1025 -> 1205 (180 kWh) x 3.500đ"
}

model MaintenanceRequest {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomNumber   String
  buildingName String
  category     String        // 'maintenance' | 'plumbing' | 'electrical' | 'internet' | 'other'
  title        String
  description  String
  imageUrl     String?       // Ảnh sự cố
  status       String        // 'pending' | 'in_progress' | 'completed' | 'rejected'
  priority     String        // 'important' | 'normal'
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  response     String?
  assignedToId String?
  assignedTo   StaffProfile? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model SpecialNote {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  content     String
  isRead      Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

model RoomAsset {
  id          String   @id @default(uuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String   // ví dụ: "Máy lạnh Daikin 1.5 HP", "Tủ lạnh Panasonic"
  code        String?  // Mã tài sản kiểm kê
  status      String   // "good" | "broken" | "need_maintenance"
  imageUrl    String?  // Ảnh thực tế bàn giao
  notes       String?
}

model Announcement {
  id          String   @id @default(uuid())
  senderId    String   // Người gửi (Super Admin hoặc Landlord)
  title       String
  content     String
  isImportant Boolean  @default(false) // Ghim lên đầu
  targetType  String   // "ALL" | "PROPERTY" | "BLOCK" | "ROOM"
  targetId    String?  // ID đối tượng nhận tương ứng
  createdAt   DateTime @default(now())
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
}
